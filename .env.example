# Path to Google service account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY_FILE=./config/service-account.json

# Polling interval in minutes (worker checks all projects)
POLL_INTERVAL_MINUTES=5

# Dashboard admin token (optional, for protecting manual trigger endpoints)
ADMIN_TOKEN=change-me-local

# Set to 'true' to enable Frase/Surfer scraping (requires Playwright browsers)
ENABLE_BROWSER_SCRAPE=false

# ----- Auth (NextAuth v5 + Google) -----
# Public URL of this app. Used by NextAuth for OAuth redirects.
NEXTAUTH_URL=http://localhost:3030

# Generate with:  openssl rand -base64 32
AUTH_SECRET=

# Google OAuth client (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: ${NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Restrict who can sign in. Set ONE of the two:
#   ALLOWED_EMAIL_DOMAIN=yourcompany.com         # any email at this domain
#   ALLOWED_EMAILS=alice@x.com,bob@y.com         # explicit allowlist
ALLOWED_EMAIL_DOMAIN=
ALLOWED_EMAILS=

# ----- App data -----
# Where SQLite + per-user browser profiles live.
# On a DO Droplet, point this at a persistent volume, e.g. /var/lib/wp-publisher
DATA_DIR=./data

# Encryption key for sensitive at-rest credentials (cookies/profiles).
# Generate with:  openssl rand -base64 32
APP_SECRET=
